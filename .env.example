# Future Self Diary — Expo app environment (PUBLIC values only)
#
# This file is for the Expo APP, not the backend.
# NEVER put OPENAI_API_KEY here. The OpenAI key lives only in backend/.env.
#
# The reflection endpoint your app calls. For a real Android build, use your
# public HTTPS backend URL (e.g. your Hostinger domain):
EXPO_PUBLIC_AI_REFLECTION_ENDPOINT=https://your-domain.com/api/reflection

# Local development options (do NOT use these in an Android build):
#   Simulator/emulator on this machine:
#   EXPO_PUBLIC_AI_REFLECTION_ENDPOINT=http://localhost:3000/api/reflection
#
#   Physical device on same Wi-Fi (replace with your PC's LAN IP):
#   EXPO_PUBLIC_AI_REFLECTION_ENDPOINT=http://10.137.13.94:3000/api/reflection
#
# Notes for Android builds:
# - EXPO_PUBLIC_* variables are bundled into the app at BUILD time.
# - If the backend URL changes, you must REBUILD the app.
# - Do NOT use localhost in an installed Android build — the phone cannot reach it.
# - Use the public HTTPS backend URL.
# - If this variable is unset, the app still works using the on-device local fallback.
